# Optional environment variables for youtube-downloader
# Copy to .env (if your runner loads env files) or export directly in your shell.

# Default faster-whisper model path/name
# YTDL_WHISPER_MODEL=/path/to/models/faster-whisper-base.en

# Preferred parent directory containing faster-whisper-base.en
# YTDL_MODEL_DIR=/path/to/models

# Default Ollama model used for --format summary
# YTD_OLLAMA_MODEL=llama3.1:8b
